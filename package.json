{
  "name": "weartoday",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cap:sync": "npm run build && npx cap sync",
    "ios:prepare": "bash scripts/prepare-ios.sh",
    "ios:open": "npx cap open ios",
    "ios:fix": "bash scripts/fix-ios-build.sh",
    "ios:pods": "cd ios/App && pod install",
    "ios:pods:update": "cd ios/App && pod install --repo-update",
    "build:ios": "CAPACITOR_BUILD=1 vite build",
    "ios:icons": "bash scripts/sync-ios-app-icon.sh",
    "ios:extensions": "ruby scripts/setup-xcode-targets.rb",
    "ios:watch-icon": "bash scripts/sync-ios-watch-icon.sh"
  },
  "dependencies": {
    "@capacitor/android": "^6.0.0",
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/geolocation": "^6.0.0",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/push-notifications": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@react-email/components": "^1.0.12",
    "@supabase/supabase-js": "^2.39.0",
    "date-fns": "^3.3.1",
    "framer-motion": "^11.0.0",
    "leaflet": "^1.9.4",
    "lucide-react": "^1.16.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-email": "^6.4.0",
    "react-is": "^18.3.1",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^6.22.0",
    "recharts": "^3.8.1",
    "resend": "^6.12.4",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@types/leaflet": "^1.9.8",
    "@types/node": "^20.11.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "postcss": "^8.4.35",
    "react-email": "^6.4.0",
    "tailwindcss": "^3.4.1",
    "typescript": "~5.3.3",
    "vite": "^5.1.0",
    "vite-plugin-pwa": "^0.19.0",
    "vitest": "^1.6.1"
  }
}
