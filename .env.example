# Required for the app (web + iOS). Copy to .env before npm run build:ios
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat Web Billing (web app only; iOS uses StoreKit)
VITE_REVENUECAT_API_KEY=your-revenuecat-web-billing-public-api-key
# Optional: defaults to "pro" — must match entitlement in RevenueCat dashboard
# VITE_REVENUECAT_ENTITLEMENT_ID=pro

# GitHub Actions (Deploy Edge Functions workflow) — see docs/SUPABASE_DEPLOY.md
# SUPABASE_ACCESS_TOKEN=your-personal-access-token
# SUPABASE_PROJECT_ID=your-project-ref   # same id as in the URL above
