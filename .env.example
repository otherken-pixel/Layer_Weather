# Supabase
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Weather API (Open-Meteo is free and requires no key)
# Optionally override with a paid provider
EXPO_PUBLIC_WEATHER_API=open-meteo

# Optional: OpenWeatherMap for fallback
EXPO_PUBLIC_OWM_KEY=your-openweathermap-api-key
